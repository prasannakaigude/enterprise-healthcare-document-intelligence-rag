# Copy this file to .env later when the app needs real configuration.
# Do not put real API keys in this example file.
# Do not commit your real .env file to GitHub.

OPENAI_API_KEY=your_openai_api_key_here

# Local application settings
APP_NAME=Enterprise Healthcare Document Intelligence RAG Platform
APP_VERSION=0.15.0
ENVIRONMENT=local
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini
CHAT_TEMPERATURE=0
CHROMA_COLLECTION_NAME=healthcare_documents

# AWS S3 settings
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your_s3_bucket_name_here
AWS_S3_RAW_PREFIX=healthcare-documents/raw

# Future local paths
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
CHROMA_DB_DIR=data/vector_db/chroma
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=4
